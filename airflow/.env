# airflow/.env
# Astro reads this automatically — do NOT prefix with AIRFLOW__ for Kafka vars

# ── Airflow webserver ──────────────────────────────────────────────────────
AIRFLOW__WEBSERVER__BASE_URL=http://localhost:8081
AIRFLOW__WEBSERVER__WEB_SERVER_PORT=8080

# ── Kafka (inside Docker, Airflow containers talk to kafka:29092) ──────────
# When Kafka is running via your root docker-compose.yml on the pipeline-net
# network, use the internal hostname. If Kafka is not running, the DAG will
# automatically fall back to simulation mode.
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC_RAW=wuzzuf_raw_jobs

# ── Staging path inside container ─────────────────────────────────────────
STAGING_DATA_PATH=/usr/local/airflow/project/data/staging
CONSUMER_BATCH_SIZE=50
PRODUCER_DELAY_MS=50
